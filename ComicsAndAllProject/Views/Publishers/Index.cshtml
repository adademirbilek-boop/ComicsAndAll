@model IEnumerable<ComicsAndAllProject.Core.Entities.Publisher>

@{
    ViewData["Title"] = "Publishers";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold mb-1">Publishers</h1>
            <p class="text-muted mb-0">Browse comic book publishers.</p>
        </div>
    </div>

    <form method="get" asp-controller="Publishers" asp-action="Index" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="name"
                   value="@ViewBag.SearchTerm"
                   class="form-control"
                   placeholder="Search publishers..." />

            <button class="btn btn-dark" type="submit">
                Search
            </button>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var publisher in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <a asp-controller="Publishers"
                   asp-action="Details"
                   asp-route-id="@publisher.Id"
                   class="text-decoration-none text-dark">

                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <span class="badge bg-dark mb-3">Publisher</span>
                            <h5 class="fw-bold mb-1">@publisher.Name</h5>
                            <p class="text-muted mb-0">View publisher series</p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
