@using ComicsAndAllProject.Core.Entities

@model ComicsAndAllProject.ViewModels.SeriesDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
    var placeholder = "https://placehold.co/300x450/111827/F9FAFB?text=Comic+Cover";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-md-3">
            <img src="@(string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? placeholder : Model.CoverImageUrl)"
                 class="img-fluid rounded shadow-sm"
                 alt="@Model.Title" />
        </div>

        <div class="col-md-9">
            <h1 class="fw-bold mb-1">@Model.Title</h1>
            <p class="text-muted fs-5">@Model.PublisherName</p>

            <div class="d-flex gap-2 mb-4">
                <span class="badge bg-dark">Series</span>
                <span class="badge bg-secondary">@Model.Issues.Count issues</span>
            </div>

            <h3 class="fw-bold mb-3">Issues</h3>

            <div class="list-group shadow-sm">
                @foreach (var issue in Model.Issues)
                {
                    <a href="#"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <strong>#@issue.IssueNumber</strong>
                            <span class="ms-2">
                                @(string.IsNullOrWhiteSpace(issue.Title) ? "Untitled Issue" : issue.Title)
                            </span>
                        </div>

                        <small class="text-muted">Issue</small>
                    </a>
                }
            </div>
        </div>
    </div>
</div>