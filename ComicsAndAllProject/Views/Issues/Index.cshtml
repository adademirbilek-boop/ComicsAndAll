@model IEnumerable<ComicsAndAllProject.Core.Entities.Issue>

@{
    ViewData["Title"] = "Issues";

    var placeholder =
        "https://placehold.co/400x600/E5E7EB/6B7280?text=Issue+Cover";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">Issues</h1>
            <p class="text-muted mb-0">
                Browse comic book issues in the database.
            </p>
        </div>

    </div>

    <div class="row g-4">

        @foreach (var issue in Model)
        {
            <div class="col-md-3">

                <div class="card h-100 border-0 shadow-sm">

                    <img src="@placeholder"
                         class="card-img-top"
                         style="height:350px; object-fit:cover;" />

                    <div class="card-body">

                        <h6 class="fw-bold">
                            @issue.Title
                        </h6>

                        <p class="text-muted mb-2">
                            #@issue.IssueNumber
                        </p>

                        <a asp-controller="Issues"
                           asp-action="Details"
                           asp-route-id="@issue.Id"
                           class="btn btn-outline-dark btn-sm">
                            Details
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>